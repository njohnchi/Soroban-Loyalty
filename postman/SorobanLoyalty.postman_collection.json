    {
      "name": "Rewards",
      "item": [
        {
          "name": "GET /user/:address/rewards",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/user/{{stellar_address}}/rewards",
              "host": ["{{base_url}}"],
              "path": ["user", "{{stellar_address}}", "rewards"]
            },
            "description": "Returns all rewards associated with a Stellar public key.\n\n**Path Parameters**\n- `address`: a valid 56-character Stellar public key (starts with `G`)\n\nSet `stellar_address` in the active environment to your wallet address."
          },
