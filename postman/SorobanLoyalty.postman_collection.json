                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"campaigns\": [\n    {\n      \"id\": 1,\n      \"merchant\": \"GAAZI4TCR3TY5OJHCTJC2A4QSY6CJWJH5IAJTGKIN2ER7LBNVKOCCWN\",\n      \"reward_amount\": 100,\n      \"expiration\": 1780000000,\n      \"active\": true,\n      \"created_at\": \"2026-04-01T10:00:00.000Z\"\n    }\n  ],\n  \"total\": 1,\n  \"limit\": 20,\n  \"offset\": 0\n}"
