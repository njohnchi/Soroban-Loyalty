    {
      "name": "Campaigns",
      "item": [
        {
          "name": "GET /campaigns",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/campaigns?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["campaigns"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Number of campaigns to return (max 100, default 20)"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Pagination offset (default 0)"
                }
              ]
            },
            "description": "Returns a paginated list of all campaigns stored in the database.\n\n**Query Parameters**\n- `limit` (optional): max results per page, capped at 100, default 20\n- `offset` (optional): number of records to skip, default 0"
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/campaigns?limit=20&offset=0",
                  "host": ["{{base_url}}"],
                  "path": ["campaigns"],
                  "query": [
                    { "key": "limit", "value": "20" },
                    { "key": "offset", "value": "0" }
