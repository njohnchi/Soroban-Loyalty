    {
      "name": "Soroban RPC (reference)",
      "description": "Claim and redeem operations are NOT REST endpoints — they are submitted directly to the Soroban RPC by the frontend after being signed by the Freighter wallet.\n\nThe requests below are provided as reference only. In practice, the frontend constructs and submits these transactions via `@stellar/stellar-sdk`.\n\n**Soroban RPC endpoint**: `{{soroban_rpc_url}}`\n\n**Contracts**:\n- Token (LYT): `{{token_contract_id}}`\n- Campaign: `{{campaign_contract_id}}`\n- Rewards: `{{rewards_contract_id}}`",
      "item": [
        {
          "name": "Claim Reward (Soroban RPC — reference)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{soroban_rpc_url}}",
              "host": ["{{soroban_rpc_url}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"sendTransaction\",\n  \"params\": {\n    \"transaction\": \"<base64-encoded XDR signed by Freighter — call rewards.claim(user_address, campaign_id)>\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Submits a signed Soroban transaction to call `rewards.claim(user_address, campaign_id)` on the Rewards contract.\n\nThis is handled by the frontend (`frontend/src/lib/soroban.ts → claimReward`). The backend only indexes the resulting on-chain event."
          },
          "response": []
        },
        {
          "name": "Redeem Reward (Soroban RPC — reference)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{soroban_rpc_url}}",
              "host": ["{{soroban_rpc_url}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"sendTransaction\",\n  \"params\": {\n    \"transaction\": \"<base64-encoded XDR signed by Freighter — call rewards.redeem(user_address, amount)>\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Submits a signed Soroban transaction to call `rewards.redeem(user_address, amount)` on the Rewards contract, which burns LYT tokens.\n\nThis is handled by the frontend (`frontend/src/lib/soroban.ts → redeemReward`). The backend only indexes the resulting on-chain event."
          },
          "response": []
        }
      ]
    }
  ]
